      "transportType": "string",
      "pattern": "^[a-fA-F0-9]{24}$",
      "example": "65f1a2b3c4d5e6f7890a1b2c"
    },
    "Instant": {
      "transportType": "string",
      "format": "date-time",
      "example": "2026-04-20T12:30:00Z"
    },
    "Map<string,object>": {
      "transportType": "object"
    }
  },
