      "process_complete_activity": {
        "method": "POST",
        "path": "/api/process-instances/activities/{actividadId}/complete",
        "authRequired": true,
        "requestBodyType": "multipart/form-data",
        "requestParts": {
          "payload": "string (JSON de CompleteActivityRequest)",
          "files": "binary[]",
          "fileFieldIds": "string[] (mismo orden que files[])"
